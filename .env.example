# Atlassian Cloud workspace base URL (no trailing slash, no /jira suffix).
# Example: https://your-company.atlassian.net
JIRA_BASE_URL=

# Email of the Atlassian account that owns the API token.
JIRA_EMAIL=

# Jira Cloud API token. Create one at:
# https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# Project key whose issues are shown on the board. Example: HDR
JIRA_PROJECT_KEY=

# Single label that scopes the board. Example: Frontend
JIRA_LABEL_FILTER=

# How many days a Done-status ticket stays on the board after being closed.
JIRA_DONE_WINDOW_DAYS=14

# Optional: comma-separated labels to hide from card displays. Useful for global
# filter labels that appear on every ticket. Example: Frontend,team-foo
JIRA_HIDE_LABELS=
