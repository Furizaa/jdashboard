{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "env": {
    "browser": true,
    "node": true,
    "es2024": true
  },
  "ignorePatterns": [
    "node_modules",
    "dist",
    ".output",
    ".vite",
    ".agents",
    ".claude",
    "src/routeTree.gen.ts"
  ]
}
