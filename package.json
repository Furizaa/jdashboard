{
  "name": "clashboard",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "lint": "oxlint",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,md}\"",
    "gen:routes": "tsr generate",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tests/e2e/tsconfig.json",
    "depcruise": "depcruise --config .dependency-cruiser.cjs src",
    "check:arch": "npx fallow || true",
    "docs:arch": "depcruise --config .dependency-cruiser.cjs --output-type dot src | dot -Tsvg -o docs/architecture.svg",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "postinstall": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "oxlint",
      "prettier --check"
    ],
    "*.{css,md,json}": [
      "prettier --check"
    ]
  },
  "dependencies": {
    "@effect/platform": "0.96.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@tanstack/react-form": "^1.29.1",
    "@tanstack/react-query": "5.100.9",
    "@tanstack/react-router": "1.169.2",
    "@tanstack/react-router-devtools": "1.166.13",
    "@tanstack/react-start": "1.167.64",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "effect": "3.21.2",
    "lucide-react": "1.14.0",
    "neverthrow": "8.2.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "ts-pattern": "5.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@effect/vitest": "0.29.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "4.2.4",
    "@tanstack/router-cli": "1.166.43",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "dependency-cruiser": "17.4.0",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.3",
    "msw": "^2.14.5",
    "oxlint": "1.63.0",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "simple-git-hooks": "2.13.1",
    "srvx": "^0.11.15",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vitest": "4.1.5"
  },
  "packageManager": "pnpm@10.0.0"
}
