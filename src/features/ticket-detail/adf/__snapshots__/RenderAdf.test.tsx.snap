exports[`RenderAdf > combined fixtures > renders a typical bug-report description (heading + paragraph + bullet list + code block) 1`] = `"<div class="space-y-3"><h2 class="text-foreground leading-snug text-lg font-semibold mt-2">Steps to reproduce</h2><p class="text-foreground/85 text-sm leading-relaxed">Open the <strong class="text-foreground font-semibold">admin panel</strong> and:</p><ol class="text-foreground/85 ml-5 list-decimal space-y-1 text-sm"><li class="[&amp;>p]:inline [&amp;>p]:text-sm"><p class="text-foreground/85 text-sm leading-relaxed">Click Settings</p></li><li class="[&amp;>p]:inline [&amp;>p]:text-sm"><p class="text-foreground/85 text-sm leading-relaxed">Run <code class="bg-muted/60 text-foreground rounded px-1 py-0.5 font-mono text-[0.85em]">npm run build</code></p></li></ol><pre class="bg-muted/50 border-border text-foreground/90 overflow-x-auto rounded-md border p-3 font-mono text-xs leading-relaxed"><code>Error: ENOENT</code></pre></div>"`;

